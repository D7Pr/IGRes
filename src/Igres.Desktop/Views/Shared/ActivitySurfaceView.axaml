<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Igres.Desktop.Controls"
             xmlns:shared="clr-namespace:Igres.Desktop.ViewModels.Shared"
             xmlns:svc="clr-namespace:Igres.Desktop.Services"
             x:Class="Igres.Desktop.Views.Shared.ActivitySurfaceView"
             x:DataType="shared:ActivitySurfaceViewModelBase">
    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Top" Padding="40,28,40,16">
            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                <StackPanel Grid.Column="0" Grid.Row="0" Spacing="4">
                    <TextBlock Classes="h1" Text="{Binding Title}" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Border Classes="chip">
                            <TextBlock Classes="chip-text">
                                <Run Text="{Binding Items.Count}" />
                                <Run Text=" loaded" />
                            </TextBlock>
                        </Border>
                        <Border Classes="chip accent" IsVisible="{Binding SelectMode}">
                            <TextBlock Classes="chip-text">
                                <Run Text="Selecting - " />
                                <Run Text="{Binding SelectedCount}" />
                                <Run Text=" item(s)" />
                            </TextBlock>
                        </Border>
                        <Border Classes="chip warning" IsVisible="{Binding UnsupportedMessage, Converter={x:Static svc:NotNullConverter.Instance}}">
                            <TextBlock Classes="chip-text" Text="{Binding UnsupportedMessage}" />
                        </Border>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" Grid.Row="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Button Classes="ghost" Content="Refresh" Command="{Binding RefreshCommand}" />
                    <Button Classes="ghost" Content="Select" Command="{Binding ToggleSelectModeCommand}" IsVisible="{Binding !SelectMode}" />
                    <Button Classes="ghost" Content="Done" Command="{Binding ToggleSelectModeCommand}" IsVisible="{Binding SelectMode}" />
                    <Button Classes="ghost" Content="Select all" Command="{Binding SelectAllCommand}" IsVisible="{Binding SelectMode}" />
                    <Button Classes="destructive" Content="{Binding RemoveSelectedActionLabel}" Command="{Binding RemoveSelectedCommand}" IsVisible="{Binding SelectMode}" />
                    <Button Classes="destructive" Content="{Binding RemoveAllActionLabel}" Command="{Binding RemoveAllCommand}" IsEnabled="{Binding CanDeleteAll}" />
                </StackPanel>
                <Border Grid.Row="1" Grid.ColumnSpan="2" Margin="0,14,0,0" Classes="card" Padding="12,10" IsVisible="{Binding IsJobActive}">
                    <DockPanel LastChildFill="True">
                        <TextBlock DockPanel.Dock="Left" Classes="body" VerticalAlignment="Center">
                            <Run Text="Running: " />
                            <Run Text="{Binding ActiveJob.ActionLabel}" FontWeight="SemiBold" />
                            <Run Text=" - " />
                            <Run Text="{Binding ActiveJob.ProcessedCount}" />
                            <Run Text=" / " />
                            <Run Text="{Binding ActiveJob.TotalCount}" />
                        </TextBlock>
                        <ProgressBar Margin="14,0,0,0"
                                     Maximum="{Binding ActiveJob.TotalCount}"
                                     Value="{Binding ActiveJob.ProcessedCount}"
                                     ShowProgressText="False" />
                    </DockPanel>
                </Border>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Bottom" Padding="40,0,40,20" IsVisible="{Binding RecentJobs.Count}">
            <StackPanel Spacing="8">
                <TextBlock Classes="caption" Text="RECENT JOBS" />
                <ItemsControl ItemsSource="{Binding RecentJobs}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Classes="chip" Margin="0,0,8,0">
                                <TextBlock Classes="chip-text">
                                    <Run Text="{Binding ActionLabel}" FontWeight="SemiBold" />
                                    <Run Text=" - " />
                                    <Run Text="{Binding Status}" />
                                    <Run Text=" | ok " />
                                    <Run Text="{Binding SucceededCount}" />
                                    <Run Text=" | fail " />
                                    <Run Text="{Binding FailedCount}" />
                                    <Run Text=" | skip " />
                                    <Run Text="{Binding SkippedCount}" />
                                </TextBlock>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </StackPanel>
        </Border>

        <Grid>
            <Border Padding="40,0,40,20" IsVisible="{Binding IsEmpty}">
                <Border Classes="card" Padding="36" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel Spacing="10" HorizontalAlignment="Center">
                        <TextBlock Classes="h2" Text="Nothing to show" />
                        <TextBlock Classes="body" Text="This surface is empty or fully cleaned up." />
                    </StackPanel>
                </Border>
            </Border>
            <Border Padding="40,0,40,20" IsVisible="{Binding UnsupportedMessage, Converter={x:Static svc:NotNullConverter.Instance}}">
                <Border Classes="card" Padding="36" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel Spacing="10" MaxWidth="480">
                        <TextBlock Classes="h2 unsupported" Text="Unsupported" />
                        <TextBlock Classes="body" TextWrapping="Wrap" Text="{Binding UnsupportedMessage}" />
                        <TextBlock Classes="subtle" Text="The app will not pretend this works. No silent failures." />
                    </StackPanel>
                </Border>
            </Border>

            <ScrollViewer IsVisible="{Binding CanList}">
                <ItemsControl ItemsSource="{Binding Items}" Padding="40,0,40,24">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="shared:ActivityItemViewModel">
                            <Border Classes="card" Margin="0,0,14,14" Width="300" Padding="0">
                                <StackPanel>
                                    <Border Height="150"
                                            CornerRadius="14,14,0,0"
                                            Background="{Binding PreviewBrush}"
                                            ClipToBounds="True">
                                        <Grid RowDefinitions="Auto,*,Auto">
                                            <controls:RemoteImage SourceUri="{Binding PreviewUri}"
                                                                  IsVisible="{Binding HasRemotePreview}"
                                                                  Stretch="UniformToFill" />
                                            <Border Grid.RowSpan="3" IsHitTestVisible="False">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                        <GradientStop Color="#12000000" Offset="0" />
                                                        <GradientStop Color="#24000000" Offset="0.55" />
                                                        <GradientStop Color="#5A000000" Offset="1" />
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>
                                            <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10" Classes="chip">
                                                <TextBlock Classes="chip-text" Text="{Binding DisplayKind}" />
                                            </Border>
                                            <Border Grid.Row="1"
                                                    Width="72"
                                                    Height="72"
                                                    CornerRadius="36"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Background="#24FFFFFF"
                                                    BorderBrush="#44FFFFFF"
                                                    BorderThickness="1.5"
                                                    IsVisible="{Binding !HasRemotePreview}">
                                                <TextBlock Text="{Binding PreviewMonogram}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           FontSize="22"
                                                           FontWeight="SemiBold"
                                                           Foreground="White" />
                                            </Border>
                                            <Border Grid.Row="2"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Bottom"
                                                    Margin="10"
                                                    Background="#32000000"
                                                    BorderBrush="#3FFFFFFF"
                                                    BorderThickness="1"
                                                    CornerRadius="999"
                                                    Padding="10,4">
                                                <TextBlock Text="{Binding DisplayAuthor}"
                                                           Foreground="White"
                                                           FontSize="11.5"
                                                           TextTrimming="CharacterEllipsis"
                                                           MaxWidth="200" />
                                            </Border>
                                            <CheckBox HorizontalAlignment="Right"
                                                      VerticalAlignment="Top"
                                                      Margin="10"
                                                      IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                      IsVisible="{Binding $parent[ItemsControl].((shared:ActivitySurfaceViewModelBase)DataContext).SelectMode}" />
                                        </Grid>
                                    </Border>
                                    <StackPanel Margin="16,14" Spacing="6">
                                        <TextBlock Classes="h3" Text="{Binding DisplayTitle}" TextWrapping="Wrap" MaxLines="2" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Classes="subtle" Text="{Binding DisplayAuthor}" />
                                        <TextBlock Classes="subtle" Text="{Binding DisplayWhen}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Border Padding="40,0,40,0" VerticalAlignment="Bottom" IsVisible="{Binding HasMore}">
                <Button Classes="ghost" HorizontalAlignment="Center" Content="Load more" Command="{Binding LoadMoreCommand}" />
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
