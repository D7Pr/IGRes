<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Igres.Desktop.Controls"
             xmlns:svc="clr-namespace:Igres.Desktop.Services"
             xmlns:vm="clr-namespace:Igres.Desktop.ViewModels.SavedCollections"
             x:Class="Igres.Desktop.Views.SavedCollections.SavedCollectionsView"
             x:DataType="vm:SavedCollectionsViewModel">
    <Grid>
        <DockPanel LastChildFill="True" IsVisible="{Binding IsInList}">
            <Border DockPanel.Dock="Top" Padding="40,28,40,16">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="h1" Text="Saved collections" />
                        <TextBlock Classes="body" Text="Inspect a collection, remove items, or delete a collection entirely. Delete collection is a stronger action than removing items." />
                    </StackPanel>
                    <Button Grid.Column="1" Classes="ghost" Content="Refresh" VerticalAlignment="Center" Command="{Binding RefreshCommand}" />
                </Grid>
            </Border>
            <Border IsVisible="{Binding UnsupportedMessage, Converter={x:Static svc:NotNullConverter.Instance}}" Padding="40,0,40,20">
                <Border Classes="card" Padding="28">
                    <StackPanel Spacing="8">
                        <TextBlock Classes="h2 unsupported" Text="Unsupported" />
                        <TextBlock Classes="body" TextWrapping="Wrap" Text="{Binding UnsupportedMessage}" />
                    </StackPanel>
                </Border>
            </Border>
            <ScrollViewer IsVisible="{Binding CanList}">
                <ItemsControl ItemsSource="{Binding Collections}" Padding="40,4,40,24">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:SavedCollectionCardViewModel">
                            <Border Classes="card" Width="320" Margin="0,0,16,16" Padding="0">
                                <StackPanel>
                                    <Grid Height="150" ColumnDefinitions="2*,*" RowDefinitions="*,*">
                                        <Border Grid.RowSpan="2"
                                                Margin="0,0,3,0"
                                                Background="{Binding PreviewABrush}"
                                                CornerRadius="14,0,0,0"
                                                ClipToBounds="True">
                                            <Grid>
                                                <controls:RemoteImage SourceUri="{Binding PreviewA}"
                                                                      IsVisible="{Binding HasPreviewAImage}"
                                                                      Stretch="UniformToFill" />
                                                <Border IsHitTestVisible="False">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                            <GradientStop Color="#12000000" Offset="0" />
                                                            <GradientStop Color="#52000000" Offset="1" />
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                </Border>
                                                <Border Width="58"
                                                        Height="58"
                                                        CornerRadius="29"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        Background="#24FFFFFF"
                                                        BorderBrush="#44FFFFFF"
                                                        BorderThickness="1.5"
                                                        IsVisible="{Binding !HasPreviewAImage}">
                                                    <TextBlock Text="{Binding PreviewMonogram}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               FontSize="18"
                                                               FontWeight="SemiBold"
                                                               Foreground="White" />
                                                </Border>
                                            </Grid>
                                        </Border>
                                        <Border Grid.Column="1"
                                                Margin="0,0,0,3"
                                                Background="{Binding PreviewBBrush}"
                                                CornerRadius="0,14,0,0"
                                                ClipToBounds="True">
                                            <Grid>
                                                <controls:RemoteImage SourceUri="{Binding PreviewB}"
                                                                      IsVisible="{Binding HasPreviewBImage}"
                                                                      Stretch="UniformToFill" />
                                                <Border Background="#26000000" IsHitTestVisible="False" />
                                            </Grid>
                                        </Border>
                                        <Border Grid.Column="1"
                                                Grid.Row="1"
                                                Background="{Binding PreviewCBrush}"
                                                ClipToBounds="True">
                                            <Grid>
                                                <controls:RemoteImage SourceUri="{Binding PreviewC}"
                                                                      IsVisible="{Binding HasPreviewCImage}"
                                                                      Stretch="UniformToFill" />
                                                <Border Background="#30000000" IsHitTestVisible="False" />
                                            </Grid>
                                        </Border>
                                    </Grid>
                                    <StackPanel Margin="18,14" Spacing="8">
                                        <TextBlock Classes="h3" Text="{Binding Collection.Name}" />
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Border Classes="chip">
                                                <TextBlock Classes="chip-text">
                                                    <Run Text="{Binding Collection.ItemCount}" FontWeight="SemiBold" />
                                                    <Run Text=" items" />
                                                </TextBlock>
                                            </Border>
                                            <Border Classes="chip">
                                                <TextBlock Classes="chip-text" Text="{Binding UpdatedLabel}" />
                                            </Border>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,6,0,0">
                                            <Button Classes="ghost"
                                                    Content="Open"
                                                    Command="{Binding $parent[ItemsControl].((vm:SavedCollectionsViewModel)DataContext).OpenCollectionCommand}"
                                                    CommandParameter="{Binding}" />
                                            <Button Classes="destructive"
                                                    Content="Delete collection"
                                                    IsEnabled="{Binding SupportsDelete}"
                                                    Command="{Binding $parent[ItemsControl].((vm:SavedCollectionsViewModel)DataContext).DeleteCollectionCommand}"
                                                    CommandParameter="{Binding}" />
                                        </StackPanel>
                                        <TextBlock Classes="subtle" Text="{Binding SupportLabel}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>

        <DockPanel LastChildFill="True" IsVisible="{Binding IsInDetail}">
            <Border DockPanel.Dock="Top" Padding="40,24,40,12">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <Button Classes="ghost" Content="Back" Command="{Binding OpenDetail.CloseCommand}" />
                    <TextBlock Grid.Column="1" Margin="16,0,0,0" Classes="h1" VerticalAlignment="Center" Text="{Binding OpenDetail.Title}" />
                    <Button Grid.Column="2"
                            Classes="destructive"
                            Content="Remove selected"
                            Command="{Binding OpenDetail.RemoveSelectedCommand}"
                            IsEnabled="{Binding OpenDetail.CanRemoveSelected}" />
                </Grid>
            </Border>
            <ScrollViewer>
                <ItemsControl ItemsSource="{Binding OpenDetail.Items}" Padding="40,0,40,24">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Classes="card" Width="300" Margin="0,0,14,14" Padding="0">
                                <StackPanel>
                                    <Border Height="140"
                                            CornerRadius="14,14,0,0"
                                            Background="{Binding PreviewBrush}"
                                            ClipToBounds="True">
                                        <Grid>
                                            <controls:RemoteImage SourceUri="{Binding PreviewUri}"
                                                                  IsVisible="{Binding HasRemotePreview}"
                                                                  Stretch="UniformToFill" />
                                            <Border IsHitTestVisible="False">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                        <GradientStop Color="#10000000" Offset="0" />
                                                        <GradientStop Color="#56000000" Offset="1" />
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>
                                            <Border Width="64"
                                                    Height="64"
                                                    CornerRadius="32"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Background="#24FFFFFF"
                                                    BorderBrush="#44FFFFFF"
                                                    BorderThickness="1.5"
                                                    IsVisible="{Binding !HasRemotePreview}">
                                                <TextBlock Text="{Binding PreviewMonogram}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           FontSize="18"
                                                           FontWeight="SemiBold"
                                                           Foreground="White" />
                                            </Border>
                                            <CheckBox HorizontalAlignment="Right"
                                                      VerticalAlignment="Top"
                                                      Margin="10"
                                                      IsChecked="{Binding IsSelected, Mode=TwoWay}" />
                                        </Grid>
                                    </Border>
                                    <StackPanel Margin="16,14" Spacing="4">
                                        <TextBlock Classes="h3" Text="{Binding DisplayTitle}" TextTrimming="CharacterEllipsis" MaxLines="2" TextWrapping="Wrap" />
                                        <TextBlock Classes="subtle" Text="{Binding DisplayAuthor}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>
    </Grid>
</UserControl>
